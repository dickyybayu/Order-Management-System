        { "name": "Update user", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{supervisorEmail}}\",\n  \"fullName\": \"Local Supervisor Updated\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/users/{{supervisorUserId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{supervisorUserId}}"] } } },
        { "name": "Update user status", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"isActive\": true\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/users/{{supervisorUserId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{supervisorUserId}}", "status"] } } },
        { "name": "Update user role", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"role\": \"supervisor\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/users/{{supervisorUserId}}/role", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "{{supervisorUserId}}", "role"] } } }
