  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Health returns 200', function () { pm.response.to.have.status(200); });"] }
            }
          ]
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register sales operator",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{salesOperatorEmail}}\",\n  \"password\": \"{{salesOperatorPassword}}\",\n  \"fullName\": \"Local Sales Operator\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('Register returns 201 or duplicate 409', function () { pm.expect([201, 409]).to.include(pm.response.code); });", "if (pm.response.code === 201) { const body = pm.response.json(); pm.environment.set('salesOperatorUserId', body.data.id); }"] }
            }
          ]
        },
        {
          "name": "Login admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Login admin returns 200', function () { pm.response.to.have.status(200); });", "const body = pm.response.json();", "pm.environment.set('accessToken', body.data.accessToken);", "pm.environment.set('adminUserId', body.data.user.id);"] } }
          ]
        },
        {
          "name": "Login supervisor",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{supervisorEmail}}\",\n  \"password\": \"{{supervisorPassword}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Login supervisor returns 200', function () { pm.response.to.have.status(200); });", "const body = pm.response.json();", "pm.environment.set('accessToken', body.data.accessToken);", "pm.environment.set('supervisorUserId', body.data.user.id);"] } }
          ]
        },
        {
          "name": "Login sales operator",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{salesOperatorEmail}}\",\n  \"password\": \"{{salesOperatorPassword}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Login sales operator returns 200', function () { pm.response.to.have.status(200); });", "const body = pm.response.json();", "pm.environment.set('accessToken', body.data.accessToken);", "pm.environment.set('salesOperatorUserId', body.data.user.id);"] } }
          ]
        }
      ]
