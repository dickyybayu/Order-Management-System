    {
      "name": "Reports / Background Jobs",
      "item": [
        {
          "name": "Get daily sales report",
          "request": {
            "description": "Read-only endpoint for retrieving an already-generated persisted daily sales report. Requires admin or supervisor.",
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/daily-sales?date={{dailySalesReportDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reports", "daily-sales"],
              "query": [{ "key": "date", "value": "{{dailySalesReportDate}}" }]
            }
          }
        },
        {
          "name": "Development only - run daily sales report job",
          "request": {
            "description": "Development-only diagnostic endpoint. This route is mapped only when ASPNETCORE_ENVIRONMENT=Development and is excluded from Swagger.",
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/dev/jobs/daily-sales-report/run", "host": ["{{baseUrl}}"], "path": ["api", "v1", "dev", "jobs", "daily-sales-report", "run"] }
          }
