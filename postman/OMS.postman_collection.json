  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5009" },
    { "key": "accessToken", "value": "" },
    { "key": "adminUserId", "value": "" },
    { "key": "salesOperatorUserId", "value": "" },
    { "key": "supervisorUserId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "supplierId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "customerId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "dailySalesReportDate", "value": "2026-07-19" }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response is not a server error', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
