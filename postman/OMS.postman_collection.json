{
  "info": {
    "_postman_id": "6ba9982e-d4d1-4dc1-a342-fb597808e0c3",
    "name": "OMS API",
    "description": "Order Management System API collection for local development. Set local credentials in the environment before running login requests. No production secrets or JWTs are stored in this collection.",
