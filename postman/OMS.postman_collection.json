      "item": [
        {
          "name": "Get USD to IDR exchange rate",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/exchange-rates?from=USD&to=IDR",
              "host": ["{{baseUrl}}"],
